      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/vehicles/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
